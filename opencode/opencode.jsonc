// DOC: https://opencode.ai/docs/
//
// NOTE: Zen models pricing: https://opencode.ai/docs/zen/#pricing
{
  "$schema": "https://opencode.ai/config.json",

  // Updates are fully managed by Nix, OC can't do anything about it
  "autoupdate": false,

  "default_agent": "plan",
  "small_model": "opencode/big-pickle", // Free model (not very smart..)

  "plugin": [
    // Plugin for Dynamic Context Pruning
    // see: https://github.com/Opencode-DCP/opencode-dynamic-context-pruning
    // Gives /dcp command, but should be used automatically by the models
    "@tarquinen/opencode-dcp@latest",
    // Plugin for #foo snippet expansion in prompt, very flexible!
    // see: https://github.com/JosXa/opencode-snippets
    // NOTE: need to have the same in `tui.jsonc` for completions in TUI
    "opencode-snippets@latest"
  ]
}
