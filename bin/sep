#!/usr/bin/env bash
# Print a visual separator line, optionally without surrounding blank lines.

set -euo pipefail # Safe, strict script execution

COMPACT=false
if [[ "${1:-}" == "--compact" ]]; then
    COMPACT=true
fi

[[ "$COMPACT" == false ]] && echo
echo "<---------------------->"
[[ "$COMPACT" == false ]] && echo

true # necessary to always end the script with status ok
