#!/usr/bin/env bash
# Convert a byte count into a human-readable IEC size (e.g. 1.3KiB).

set -euo pipefail # Safe, strict script execution

if [[ $# != 1 ]]; then
  >&2 echo "Usage: human-size [-]NUMBER_OF_BYTES"
  exit 1
fi

# NOTE: format precision is not always available, fallback to default format is it fails.
numfmt --to=iec-i --format="%.1f" -- $1 2>/dev/null || numfmt --to=iec-i -- $1
